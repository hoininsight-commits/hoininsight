# HOIN Insight Environment Variables Template
# Copy this file to .env and fill in the values

# --- Core API Keys (Required for Live Mode) ---
# Gemini API Key for LLM Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Macro Data Source (FRED)
# Get free key at: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_api_key_here

# Korea Economic Statistics System (ECOS)
# Get free key at: https://ecos.bok.or.kr/api/
ECOS_API_KEY=your_ecos_api_key_here

# Korea Public Data Portal (DATA.GO.KR)
# Used for Real Estate collection
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# DART (OpenDART)
# Used for Corporate Action / Structural Capital
OPENDART_API_KEY=your_opendart_api_key_here

# --- Optional Notifications ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Runtime Configuration ---
# HOIN_RUNTIME_MODE: offline | live (default: live)
HOIN_RUNTIME_MODE=live

# ENABLE_LEARNING: true | false (Phase 31 Narrative Engine)
ENABLE_LEARNING=false

# --- Development / Debugging ---
# HOIN_TARGET_DATE: YYYY-MM-DD (Override current date for backtesting)
# HOIN_TARGET_DATE=2026-03-05

# UI Logic Guards (Legacy/Refactor)
HOIN_LEGACY_ENFORCE=0
HOIN_LEGACY_WARN=1

# Reporter Toggles
ENABLE_BRIDGE_REPORTING=OFF
ENABLE_DECISION_DASHBOARD=ON
ENABLE_FINAL_VIEW=ON
